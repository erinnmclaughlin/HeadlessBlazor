<div class="p-3">
    <HBModalTrigger TComponent="ConfirmDialog" OnClosed="HandleClosed" class="btn btn-primary">
        Open Modal
    </HBModalTrigger>
</div>

@code {
    // Overlay/dialog styling is configured globally via AddHeadlessBlazor(configureModalDefaults: ...),
    // so no per-call ModalOptions are needed here.
    private void HandleClosed(ModalResult result)
    {
        Console.WriteLine(result.Cancelled ? "Modal cancelled" : $"Modal confirmed: {result.Data}");
    }
}

@using Microsoft.AspNetCore.Components.Forms
@typeparam TModel where TModel : notnull

<EditForm EditContext="EditContext.Context" OnSubmit="@HandleSubmit" @attributes="UserAttributes">
    <fieldset disabled="@Disabled" style="display: contents">
        @ChildContent?.Invoke(this)
    </fieldset>
</EditForm>

@code {

    private HBEditContext<TModel> EditContext
    {
        get => field ??= new HBEditContext<TModel>(Model);
        set;
    }

    /// <summary>
    /// Whether a submit is currently in progress - that is, from the moment validation begins until
    /// the <see cref="OnValidSubmit"/> / <see cref="OnInvalidSubmit"/> handler completes. Child content
    /// can read this (via the form passed as context) to reflect the submitting state, e.g. showing a
    /// spinner. When <see cref="DisableWhileSubmitting"/> is set, this also drives <see cref="Disabled"/>.
    /// </summary>
    public bool IsSubmitting
    {
        get;
        private set
        {
            field = value;

            if (DisableWhileSubmitting)
            {
                Disabled = value;
                
                if (OnDisabledChanged.HasDelegate)
                {
                    _ = OnDisabledChanged.InvokeAsync(value);
                }
            }
        }
    }
    
    /// <summary>
    /// The form's content. Receives the <see cref="HBEditForm{TModel}"/> itself as context, so controls
    /// can read state such as <see cref="IsSubmitting"/>. Place inputs, <c>ValidationMessage</c>s and a
    /// submit button here; add a <c>DataAnnotationsValidator</c> to enable data-annotation validation.
    /// </summary>
    [Parameter]
    public RenderFragment<HBEditForm<TModel>>? ChildContent { get; set; }

    /// <summary>
    /// Whether the form is disabled. When set, the underlying <c>fieldset</c> is disabled, blocking input
    /// and submission. Supports two-way binding via <c>@bind-Disabled</c>; while
    /// <see cref="DisableWhileSubmitting"/> is set, the form toggles this for the duration of a submit.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Raised when <see cref="Disabled"/> changes, enabling <c>@bind-Disabled</c>.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OnDisabledChanged { get; set; }

    /// <summary>
    /// When <see langword="true"/>, the form disables itself (see <see cref="Disabled"/>) for the
    /// duration of each submit, preventing re-entrant submits and edits while an async handler runs.
    /// </summary>
    [Parameter]
    public bool DisableWhileSubmitting { get; set; }

    /// <summary>
    /// The model to edit and validate. Required. Swapping the reference rebuilds the edit context.
    /// </summary>
    [Parameter, EditorRequired]
    public TModel Model { get; set; } = default!;

    /// <summary>
    /// An optional validation callback invoked on submit after built-in validation passes. Receives the
    /// <see cref="HBEditContext{TModel}"/> so it can add cross-field errors via
    /// <see cref="HBEditContext{TModel}.ValidationErrors"/>; any errors it adds mark the submit invalid.
    /// </summary>
    [Parameter]
    public Func<HBEditContext<TModel>, Task>? Validation { get; set; }

    /// <summary>
    /// Invoked with the <see cref="Model"/> when the form is submitted and passes validation.
    /// </summary>
    [Parameter]
    public EventCallback<TModel> OnValidSubmit { get; set; }

    /// <summary>
    /// Invoked with the <see cref="Model"/> when the form is submitted but fails validation.
    /// </summary>
    [Parameter]
    public EventCallback<TModel> OnInvalidSubmit { get; set; }

    /// <summary>
    /// Additional attributes applied to the rendered <c>form</c> element, e.g. <c>class</c> or <c>id</c>.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object?> UserAttributes { get; set; } = new Dictionary<string, object?>();

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(EditContext.Model, Model))
        {
            EditContext = new HBEditContext<TModel>(Model);
        }
    }

    private async Task HandleSubmit()
    {
        if (IsSubmitting)
            return;
        
        IsSubmitting = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (!EditContext.Revalidate())
            {
                await OnInvalidSubmit.InvokeAsync(Model);
                return;
            }
            
            if (Validation is not null)
            {
                await Validation.Invoke(EditContext);
                EditContext.NotifyValidationStateChanged();

                if (!EditContext.IsValid())
                {
                    await OnInvalidSubmit.InvokeAsync(Model);
                    return;
                }
            }
            
            await OnValidSubmit.InvokeAsync(Model);
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
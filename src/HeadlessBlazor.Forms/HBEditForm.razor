@using Microsoft.AspNetCore.Components.Forms
@typeparam TModel where TModel : notnull

<EditForm EditContext="FormContext.Context" OnSubmit="@HandleSubmit" @attributes="UserAttributes">
    <fieldset disabled="@IsDisabled" style="display: contents">
        @ChildContent?.Invoke(this)
    </fieldset>
</EditForm>

@code {

    /// <summary>
    /// The <see cref="HBEditContext{TModel}"/> backing this form. Exposed so child content can add
    /// validation errors outside of the <see cref="Validation"/> submit hook - e.g. from an async
    /// remote-validation check on blur - via <c>context.FormContext.ValidationErrors</c>, followed by
    /// <see cref="HBEditContext{TModel}.NotifyValidationStateChanged"/> to refresh bound
    /// <c>ValidationMessage</c>s.
    /// </summary>
    public HBEditContext<TModel> FormContext
    {
        get => field ??= new HBEditContext<TModel>(Model);
        private set;
    }

    /// <summary>
    /// Whether a submit is currently in progress - that is, from the moment validation begins until
    /// the <see cref="OnValidSubmit"/> / <see cref="OnInvalidSubmit"/> handler completes. Child content
    /// can read this (via the form passed as context) to reflect the submitting state, e.g. showing a
    /// spinner. When <see cref="DisableWhileSubmitting"/> is set, this also feeds into <see cref="IsDisabled"/>.
    /// </summary>
    public bool IsSubmitting { get; private set; }

    /// <summary>
    /// Whether the underlying <c>fieldset</c> is currently disabled - either because the caller set
    /// <see cref="Disabled"/>, or because <see cref="DisableWhileSubmitting"/> is set and a submit is in
    /// progress. Unlike <see cref="Disabled"/>, this is computed and never itself settable by the caller,
    /// so a caller-supplied <see cref="Disabled"/> value is never overwritten once a submit completes.
    /// </summary>
    public bool IsDisabled => Disabled || (DisableWhileSubmitting && IsSubmitting);

    /// <summary>
    /// The form's content. Receives the <see cref="HBEditForm{TModel}"/> itself as context, so controls
    /// can read state such as <see cref="IsSubmitting"/> and reach <see cref="FormContext"/> to add
    /// validation errors. Place inputs, <c>ValidationMessage</c>s and a submit button here; add a
    /// <c>DataAnnotationsValidator</c> to enable data-annotation validation.
    /// </summary>
    [Parameter]
    public RenderFragment<HBEditForm<TModel>>? ChildContent { get; set; }

    /// <summary>
    /// Whether the caller wants the form disabled, e.g. because it's read-only. When set, the underlying
    /// <c>fieldset</c> is disabled, blocking input and submission. This value is entirely caller-owned -
    /// the component never modifies it itself; see <see cref="IsDisabled"/> for the effective disabled
    /// state, which also accounts for <see cref="DisableWhileSubmitting"/>.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// When <see langword="true"/>, the form disables itself (see <see cref="IsDisabled"/>) for the
    /// duration of each submit, preventing re-entrant submits and edits while an async handler runs.
    /// </summary>
    [Parameter]
    public bool DisableWhileSubmitting { get; set; }

    /// <summary>
    /// The model to edit and validate. Required. Swapping the reference rebuilds the edit context.
    /// </summary>
    [Parameter, EditorRequired]
    public TModel Model { get; set; } = default!;

    /// <summary>
    /// An optional validation callback invoked on submit after built-in validation passes. Receives the
    /// <see cref="HBEditContext{TModel}"/> so it can add cross-field errors via
    /// <see cref="HBEditContext{TModel}.ValidationErrors"/>; any errors it adds mark the submit invalid.
    /// </summary>
    [Parameter]
    public Func<HBEditContext<TModel>, Task>? Validation { get; set; }

    /// <summary>
    /// Invoked with the <see cref="Model"/> when the form is submitted and passes validation.
    /// </summary>
    [Parameter]
    public EventCallback<TModel> OnValidSubmit { get; set; }

    /// <summary>
    /// Invoked with the <see cref="Model"/> when the form is submitted but fails validation.
    /// </summary>
    [Parameter]
    public EventCallback<TModel> OnInvalidSubmit { get; set; }

    /// <summary>
    /// Additional attributes applied to the rendered <c>form</c> element, e.g. <c>class</c> or <c>id</c>.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object?> UserAttributes { get; set; } = new Dictionary<string, object?>();

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(FormContext.Model, Model))
        {
            FormContext = new HBEditContext<TModel>(Model);
        }
    }

    private async Task HandleSubmit()
    {
        if (IsSubmitting)
            return;

        IsSubmitting = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (!FormContext.Revalidate())
            {
                await OnInvalidSubmit.InvokeAsync(Model);
                return;
            }

            if (Validation is not null)
            {
                await Validation.Invoke(FormContext);
                FormContext.NotifyValidationStateChanged();

                if (!FormContext.IsValid())
                {
                    await OnInvalidSubmit.InvokeAsync(Model);
                    return;
                }
            }

            await OnValidSubmit.InvokeAsync(Model);
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
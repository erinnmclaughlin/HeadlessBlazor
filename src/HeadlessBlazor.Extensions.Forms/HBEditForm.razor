@using Microsoft.AspNetCore.Components.Forms
@typeparam TModel where TModel : notnull

<EditForm EditContext="EditContext.Context" OnSubmit="@HandleSubmit" @attributes="UserAttributes">
    <fieldset disabled="@Disabled" style="display: contents">
        @ChildContent?.Invoke(this)
    </fieldset>
</EditForm>

@code {

    private HBEditContext<TModel> EditContext
    {
        get => field ??= new HBEditContext<TModel>(Model);
        set;
    }

    public bool IsSubmitting
    {
        get;
        private set
        {
            field = value;

            if (DisableWhileSubmitting)
            {
                Disabled = value;
                
                if (OnDisabledChanged.HasDelegate)
                {
                    _ = OnDisabledChanged.InvokeAsync(value);
                }
            }
        }
    }
    
    [Parameter]
    public RenderFragment<HBEditForm<TModel>>? ChildContent { get; set; }
    
    [Parameter]
    public bool Disabled { get; set; }
    
    [Parameter]
    public EventCallback<bool> OnDisabledChanged { get; set; }
    
    [Parameter]
    public bool DisableWhileSubmitting { get; set; }
    
    [Parameter, EditorRequired]
    public TModel Model { get; set; } = default!;
    
    [Parameter]
    public Func<HBEditContext<TModel>, Task>? Validation { get; set; }

    [Parameter]
    public EventCallback<TModel> OnValidSubmit { get; set; }
    
    [Parameter]
    public EventCallback<TModel> OnInvalidSubmit { get; set; }
    
    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object?> UserAttributes { get; set; } = new Dictionary<string, object?>();

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(EditContext.Model, Model))
        {
            EditContext = new HBEditContext<TModel>(Model);
        }
    }

    private async Task HandleSubmit()
    {
        if (IsSubmitting)
            return;
        
        IsSubmitting = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (!EditContext.Revalidate())
            {
                await OnInvalidSubmit.InvokeAsync(Model);
                return;
            }
            
            if (Validation is not null)
            {
                await Validation.Invoke(EditContext);
                EditContext.NotifyValidationStateChanged();

                if (!EditContext.IsValid())
                {
                    await OnInvalidSubmit.InvokeAsync(Model);
                    return;
                }
            }
            
            await OnValidSubmit.InvokeAsync(Model);
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
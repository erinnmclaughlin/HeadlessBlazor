@implements IAsyncDisposable
@namespace HeadlessBlazor
@using Microsoft.JSInterop
@inject IJSRuntime JS

@code {
    private IJSObjectReference? _handlerRef;

    private bool Initialized { get; set; }
    private bool Disposed { get; set; }

    /// <summary>
    /// A reference to the element to relocate to the end of the document body.
    /// </summary>
    [Parameter, EditorRequired]
    public required ElementReference Element { get; set; }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        // Set before awaiting anything below, so a disposal that races with an in-flight
        // OnAfterRenderAsync (e.g. the last toast is dismissed before JS interop finishes
        // initializing) is visible to that continuation before it touches Element - by then
        // the underlying DOM node may already be gone.
        Disposed = true;

        if (_handlerRef is not null)
        {
            try
            {
                await _handlerRef.InvokeVoidAsync("dispose");
                await _handlerRef.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // The Blazor Server circuit was already torn down (e.g. page refresh), so the
                // JS-side handle is gone too - nothing to dispose. Safe to ignore.
            }

            _handlerRef = null;
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The captured element reference may not be populated on the first render,
        // so initialize as soon as it has a value rather than gating on firstRender.
        if (!Initialized && !string.IsNullOrEmpty(Element.Id))
        {
            Initialized = true;
            const string moduleName = nameof(HBPortalBehavior);

            try
            {
                var module = await JS.InvokeAsync<IJSObjectReference>("import", $"./_content/HeadlessBlazor.Toast/{moduleName}.razor.js");

                if (Disposed)
                {
                    await module.DisposeAsync();
                    return;
                }

                var handler = await module.InvokeAsync<IJSObjectReference>($"{moduleName}.createInstance", Element);
                await module.DisposeAsync();

                if (Disposed)
                {
                    // Disposed while createInstance was in flight - don't hand off a
                    // handle nothing will ever dispose; tear it down immediately.
                    await handler.InvokeVoidAsync("dispose");
                    await handler.DisposeAsync();
                    return;
                }

                _handlerRef = handler;
            }
            catch (JSDisconnectedException)
            {
                // The Blazor Server circuit disconnected mid-initialization (e.g. a refresh
                // landing between renders). There's nothing to wire up or clean up - the JS
                // side is gone with the circuit. Safe to ignore.
            }
        }
    }
}

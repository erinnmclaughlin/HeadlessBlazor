@implements IAsyncDisposable
@namespace HeadlessBlazor
@using Microsoft.JSInterop

@code {
    private IJSObjectReference? handlerRef;
    private bool initialized;
    private bool disposed;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    /// <summary>
    /// A reference to the element within which focus should be trapped.
    /// </summary>
    [Parameter, EditorRequired]
    public required ElementReference Element { get; set; }

    /// <inheritdoc />
    public async ValueTask DisposeAsync()
    {
        // Set before awaiting anything below, so a disposal that races with an
        // in-flight OnAfterRenderAsync (e.g. the modal is closed again before JS
        // interop finishes initializing) is visible to that continuation before it
        // touches Element - by then the underlying DOM node may already be gone.
        disposed = true;

        if (handlerRef is not null)
        {
            await handlerRef.InvokeVoidAsync("dispose");
            await handlerRef.DisposeAsync();
            handlerRef = null;
        }
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // The captured element reference may not be populated on the first render,
        // so initialize as soon as it has a value rather than gating on firstRender.
        if (!initialized && !string.IsNullOrEmpty(Element.Id))
        {
            initialized = true;
            const string moduleName = nameof(HBFocusTrapBehavior);
            var module = await JS.InvokeAsync<IJSObjectReference>("import", $"./_content/HeadlessBlazor.Modal/{moduleName}.razor.js");

            if (disposed)
            {
                await module.DisposeAsync();
                return;
            }

            var handler = await module.InvokeAsync<IJSObjectReference>($"{moduleName}.createInstance", Element);
            await module.DisposeAsync();

            if (disposed)
            {
                // Disposed while createInstance was in flight - don't hand off a
                // handle nothing will ever dispose; tear it down immediately.
                await handler.InvokeVoidAsync("dispose");
                await handler.DisposeAsync();
                return;
            }

            handlerRef = handler;
        }
    }
}
